# Core / App
NODE_ENV=development
PORT=3210
NETWORK=testnet-10
FRONTEND_URL=http://localhost:3210

# Database (SQLite by default; set DB_DRIVER=postgres to switch)
DB_DRIVER=sqlite
KASPANOTAR_DB_PATH=./kaspanotar.db
# DATABASE_URL=postgres://user:pass@host:5432/kaspanotar
DB_POOL_MIN=2
DB_POOL_MAX=20
DB_SSL=0

# CORS
CORS_ORIGINS=http://localhost:3210

# Rate limiting
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_ANCHOR_MAX=5

# Logging
LOG_LEVEL=info

# Kaspa network (leave unset to use the SDK's built-in public Resolver)
# KASPA_RPC_URL=
KASPA_API_URL=https://api-tn10.kaspa.org

# Anchor wallet (created via `npm run wallet:generate`)
ANCHOR_WALLET_ENCRYPTION_KEY=change-me-to-a-strong-passphrase
ANCHOR_WALLET_KEYSTORE_PATH=./anchor-wallet.keystore.json

# Wallet login (Sign-in with Wallet, self-pay anchoring) -- required, no default
JWT_SECRET=change-me-to-a-random-64-char-hex-string
RATE_LIMIT_AUTH_MAX=20
